{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!sitemap\\.xml|robots\\.txt).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/auto-chase",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/social-post",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/social-post?mode=engage",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/social-post?mode=engage",
      "schedule": "0 15 * * *"
    }
  ]
}
